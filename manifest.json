{
  "manifest_version": 3,
  "name": "Web Sanitizer",
  "version": "1.0",
  "description": "Web sanitizer",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "src/assets/images/dog1.jpg",
      "48": "src/assets/images/dog2.png",
      "128": "src/assets/images/dog3.jpg"
    }
  },
  "background": {
    "service_worker": "src/scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/content.js"]
    }
  ]
}
